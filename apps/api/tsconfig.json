{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "*.ts"],
  "compilerOptions": {
    "declaration": true /* Generates corresponding '.d.ts' file */,
    "declarationMap": true /* Optional: allows VS Code to jump to source */,
    "emitDeclarationOnly": false /* Set to true if you only want types, not JS */,
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "../.."
  }
}
